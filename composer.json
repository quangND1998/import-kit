{
    "name": "happtime/import-kit",
    "description": "Reusable Laravel import module for Excel/CSV preview and async commit.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0",
        "illuminate/queue": "^10.0 || ^11.0 || ^12.0",
        "illuminate/filesystem": "^10.0 || ^11.0 || ^12.0",
        "phpoffice/phpspreadsheet": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\ImportKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\ImportKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\ImportKit\\ImportKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
